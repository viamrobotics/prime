{
  "name": "@viamrobotics/tweakpane-config",
  "version": "0.1.0",
  "description": "Viam-themed configuration for svelte-tweakpane-ui.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viamrobotics/prime.git",
    "directory": "packages/tweakpane-config"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "tsc -p tsconfig.build.json && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "svelte-tweakpane-ui": "^1.5.16"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24",
    "@viamrobotics/tailwind-config": "workspace:^",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.18",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "svelte-tweakpane-ui": "^1.5.16",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.7"
  },
  "keywords": [
    "svelte",
    "tweakpane",
    "viam"
  ]
}
