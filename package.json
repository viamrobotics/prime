{
  "name": "@viamrobotics/prime-repo",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "http://viamrobotics.github.io/prime",
  "repository": "git://github.com/viamrobotics/prime.git",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "app:docs": "pnpm --filter @viamrobotics/prime-docs dev",
    "packages:ui": "pnpm --filter @viamrobotics/prime-ui dev",
    "build": "pnpm -r run --if-present build",
    "check": "pnpm -r run --if-present check",
    "lint": "dprint check && pnpm -r run --if-present lint",
    "test": "pnpm -r run --if-present test",
    "format": "dprint fmt && pnpm -r run --if-present format",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "dprint": "^0.54.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "dprint"
    ]
  }
}
